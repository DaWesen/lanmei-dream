        </mxCell>

        <!-- 蓝妹服务 -->
        <mxCell id="svc" value="蓝妹服务" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#d5e8d4;strokeColor=#82b366;verticalAlign=top;fontStyle=1" vertex="1" parent="1">
          <mxGeometry x="320" y="40" width="280" height="220" as="geometry"/>
        </mxCell>
        <mxCell id="main" value="main.go" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#fff2cc;strokeColor=#d6b656" vertex="1" parent="1">

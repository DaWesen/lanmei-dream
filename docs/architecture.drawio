        <mxCell id="e6" style="endArrow=block;html=1" source="chatsvc" target="llm" parent="1"/>
        <mxCell id="e7" style="endArrow=block;html=1" source="chatsvc" target="emb" parent="1"/>
        <mxCell id="e8" style="endArrow=block;html=1" source="chatsvc" target="memstore" parent="1"/>
        <mxCell id="e9" style="endArrow=block;html=1" source="memstore" target="mv" parent="1"/>
        <mxCell id="e10" style="endArrow=block;html=1" source="rp" target="pg" parent="1"/>
        <mxCell id="e11" style="endArrow=block;html=1" source="cmdsys" target="signin" parent="1"/>
        <mxCell id="e12" style="endArrow=block;html=1;dashed=1" source="chatsvc" target="pg" parent="1"/>
